{
  "name": "luber-sui",
  "version": "0.1.0",
  "private": true,
  "description": "Luber — MCP-first autonomous portfolio-correlation LP risk agent on Sui (Sui Overflow 2026, Agentic Web)",
  "scripts": {
    "dev": "pnpm --filter @luber/web dev",
    "dev:web": "pnpm --filter @luber/web dev",
    "dev:server": "pnpm --filter @luber/server dev",
    "dev:mcp": "pnpm --filter @luber/mcp-server dev",
    "dev:mcp:http": "pnpm --filter @luber/mcp-server dev:http",
    "build": "pnpm --filter @luber/web build",
    "build:core": "pnpm --filter @luber/core build",
    "build:server": "pnpm --filter @luber/server build",
    "build:mcp": "pnpm --filter @luber/mcp-server build",
    "typecheck": "pnpm -r typecheck",
    "data:dev": "cd services/be-data && uvicorn main:app --reload --port 8000"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.2"
}
